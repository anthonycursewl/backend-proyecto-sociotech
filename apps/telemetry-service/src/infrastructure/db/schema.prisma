generator client {
  provider = "prisma-client-js"
  output   = "../../../../../node_modules/@prisma/client/telemetry"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@map("audit_logs")
  @@index([entityType, entityId])
  @@index([userId])
}
