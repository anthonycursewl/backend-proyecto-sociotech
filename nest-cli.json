{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/backend-proyecto-sociotech/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "**/*.prisma"
    ],
    "watchAssets": true,
    "webpack": true,
    "tsConfigPath": "apps/backend-proyecto-sociotech/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/backend-proyecto-sociotech",
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "backend-proyecto-sociotech": {
      "type": "application",
      "root": "apps/backend-proyecto-sociotech",
      "entryFile": "main",
      "sourceRoot": "apps/backend-proyecto-sociotech/src",
      "compilerOptions": {
        "tsConfigPath": "apps/backend-proyecto-sociotech/tsconfig.app.json"
      }
    },
    "main-service": {
      "type": "application",
      "root": "apps/clinical-service",
      "entryFile": "main",
      "sourceRoot": "apps/clinical-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/clinical-service/tsconfig.app.json"
      }
    },
    "scheduling-service": {
      "type": "application",
      "root": "apps/scheduling-service",
      "entryFile": "main",
      "sourceRoot": "apps/scheduling-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/scheduling-service/tsconfig.app.json"
      }
    },
    "sync-service": {
      "type": "application",
      "root": "apps/sync-service",
      "entryFile": "main",
      "sourceRoot": "apps/sync-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sync-service/tsconfig.app.json"
      }
    },
    "telemetry-service": {
      "type": "application",
      "root": "apps/telemetry-service",
      "entryFile": "main",
      "sourceRoot": "apps/telemetry-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/telemetry-service/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    }
  }
}
