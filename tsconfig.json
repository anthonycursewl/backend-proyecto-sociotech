{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@clinical/application/*": [
        "apps/main-service/src/application/*"
      ],
      "@clinical/domain/*": [
        "apps/main-service/src/domain/*"
      ],
      "@clinical/infrastructure/*": [
        "apps/main-service/src/infrastructure/*"
      ],
      "@identity/application/*": [
        "apps/auth-service/src/application/*"
      ],
      "@identity/domain/*": [
        "apps/auth-service/src/domain/*"
      ],
      "@identity/infrastructure/*": [
        "apps/auth-service/src/infrastructure/*"
      ],
      "@prisma/*": [
        "apps/backend-proyecto-sociotech/src/prisma/*"
      ],
      "@scheduling/application/*": [
        "apps/main-service/src/application/*"
      ],
      "@scheduling/domain/*": [
        "apps/main-service/src/domain/*"
      ],
      "@scheduling/infrastructure/*": [
        "apps/main-service/src/infrastructure/*"
      ],
      "@shared/*": [
        "apps/backend-proyecto-sociotech/src/modules/shared/*"
      ],
      "@shared/notification/*": [
        "apps/backend-proyecto-sociotech/src/modules/shared/infrastructure/notification/*"
      ]
    }
  },
  "include": [
    "apps/**/*",
    "libs/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
